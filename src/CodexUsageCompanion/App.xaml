<Application x:Class="CodexUsageCompanion.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#171719" />
        <SolidColorBrush x:Key="BorderBrush" Color="#343438" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F0F0F2" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#9B9BA1" />
        <SolidColorBrush x:Key="TrackBrush" Color="#343439" />
        <SolidColorBrush x:Key="ProgressBrush" Color="#B8B8BE" />
        <SolidColorBrush x:Key="SyncedBrush" Color="#70D89A" />
        <SolidColorBrush x:Key="InactiveBrush" Color="#68686E" />
    </Application.Resources>
</Application>
