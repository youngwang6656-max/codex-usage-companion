<Window x:Class="CodexUsageCompanion.UsageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Codex Usage Companion"
        Width="800"
        Height="50"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Background="#171719"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="False"
        Focusable="False"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        FontSize="14"
        FontWeight="Normal"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <Window.Resources>
        <Style x:Key="IconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#252528" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#303034" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="13"
            ClipToBounds="True">
        <Grid x:Name="ContentGrid" Margin="16,0,18,0" ClipToBounds="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left">
                <TextBlock x:Name="CodexText"
                           Text="Codex"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="PlanText"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Margin="4,0,0,0"
                           VerticalAlignment="Center" />
                <Ellipse x:Name="SyncDot"
                         Width="7"
                         Height="7"
                         Fill="{StaticResource InactiveBrush}"
                         Margin="14,0,7,0"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="LimitText"
                           Text="每周使用限制"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Margin="22,0,0,0"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="RemainingText"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center" />
                <Grid Width="100"
                      Height="5"
                      Margin="10,1,0,0"
                      VerticalAlignment="Center"
                      ClipToBounds="True">
                    <Border Background="{StaticResource TrackBrush}" CornerRadius="3" />
                    <Border x:Name="ProgressFill"
                            Width="0"
                            Background="{StaticResource ProgressBrush}"
                            CornerRadius="3"
                            HorizontalAlignment="Left" />
                </Grid>
                <TextBlock x:Name="ResetTimeText"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Margin="24,0,0,0"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="ResetCreditsText"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Margin="22,0,0,0"
                           VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel x:Name="ActionPanel"
                        Grid.Column="1"
                        Orientation="Horizontal"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center">
                <Button x:Name="RefreshButton"
                        Style="{StaticResource IconButtonStyle}"
                        AutomationProperties.Name="立即刷新"
                        Click="OnRefreshClicked"
                        ToolTip="立即刷新">
                    <Path Width="18"
                          Height="18"
                          Stretch="Uniform"
                          StrokeThickness="1.5"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                          Data="M 21,12 A 9,9 0 0 0 5.83,5.45 L 3,8 M 3,3 L 3,8 L 8,8 M 3,12 A 9,9 0 0 0 18.17,18.55 L 21,16 M 16,16 L 21,16 L 21,21" />
                </Button>
                <Button x:Name="VisibilityButton"
                        Style="{StaticResource IconButtonStyle}"
                        Margin="4,0,0,0"
                        AutomationProperties.Name="收起 Codex 用量组件"
                        Click="OnVisibilityClicked"
                        ToolTip="收起组件">
                    <Path Width="18"
                          Height="18"
                          Stretch="Uniform"
                          StrokeThickness="1.5"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                          Data="M 12,2 L 12,12 M 6.6,5.3 A 8,8 0 1 0 17.4,5.3" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
